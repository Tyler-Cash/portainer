{
  "uid": "peepbot-jvm",
  "title": "Peep Bot — JVM & Host",
  "tags": ["peepbot", "jvm"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "editable": false,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" },
        "hide": 0
      },
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(application_ready_time_milliseconds{service_namespace=\"peep-bot\"}, service_name)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": { "text": "peepbot-backend", "value": "peepbot-backend" }
      },
      {
        "name": "env",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(application_ready_time_milliseconds{service_namespace=\"peep-bot\"}, deployment_environment_name)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": { "text": "production", "value": "production" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Heap by region (stacked)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_memory_used_bytes{service_namespace=\"peep-bot\", service_name=~\"$service\", deployment_environment_name=~\"$env\", area=\"heap\"}",
          "legendFormat": "{{id}}"
        },
        {
          "refId": "B",
          "expr": "jvm_memory_max_bytes{service_namespace=\"peep-bot\", service_name=~\"$service\", deployment_environment_name=~\"$env\", area=\"heap\"}",
          "legendFormat": "max {{id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "^max .*" },
            "properties": [
              { "id": "custom.stacking", "value": { "mode": "none" } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }
            ]
          }
        ]
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Heap utilization",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(jvm_memory_used_bytes{service_namespace=\"peep-bot\", service_name=~\"$service\", deployment_environment_name=~\"$env\", area=\"heap\"}) / sum(jvm_memory_max_bytes{service_namespace=\"peep-bot\", service_name=~\"$service\", deployment_environment_name=~\"$env\", area=\"heap\"} > 0)"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "GC overhead",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_gc_overhead{service_namespace=\"peep-bot\", service_name=~\"$service\", deployment_environment_name=~\"$env\"}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Non-heap by region (stacked)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_memory_used_bytes{service_namespace=\"peep-bot\", service_name=~\"$service\", deployment_environment_name=~\"$env\", area=\"nonheap\"}",
          "legendFormat": "{{id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "stacking": { "mode": "normal", "group": "A" }
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "GC pause p99 + rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(jvm_gc_pause_milliseconds_bucket{service_namespace=\"peep-bot\", service_name=~\"$service\", deployment_environment_name=~\"$env\"}[5m])))",
          "legendFormat": "p99 pause"
        },
        {
          "refId": "B",
          "expr": "sum(rate(jvm_gc_pause_milliseconds_count{service_namespace=\"peep-bot\", service_name=~\"$service\", deployment_environment_name=~\"$env\"}[5m]))",
          "legendFormat": "rate"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "rate" },
            "properties": [
              { "id": "unit", "value": "ops" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Allocation rate",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(jvm_gc_memory_allocated_bytes_total{service_namespace=\"peep-bot\", service_name=~\"$service\", deployment_environment_name=~\"$env\"}[5m]))",
          "legendFormat": "allocation"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Thread states (stacked)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (state) (jvm_threads_states{service_namespace=\"peep-bot\", service_name=~\"$service\", deployment_environment_name=~\"$env\"})",
          "legendFormat": "{{state}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 50,
            "stacking": { "mode": "normal", "group": "A" }
          }
        }
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Live threads",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_threads_live{service_namespace=\"peep-bot\", service_name=~\"$service\", deployment_environment_name=~\"$env\"}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Daemon threads",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_threads_daemon{service_namespace=\"peep-bot\", service_name=~\"$service\", deployment_environment_name=~\"$env\"}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Peak threads",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_threads_peak{service_namespace=\"peep-bot\", service_name=~\"$service\", deployment_environment_name=~\"$env\"}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "File descriptors",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "process_files_open{service_namespace=\"peep-bot\", service_name=~\"$service\", deployment_environment_name=~\"$env\"}",
          "legendFormat": "open"
        },
        {
          "refId": "B",
          "expr": "process_files_max{service_namespace=\"peep-bot\", service_name=~\"$service\", deployment_environment_name=~\"$env\"}",
          "legendFormat": "max"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "process_uptime_milliseconds{service_namespace=\"peep-bot\", service_name=~\"$service\", deployment_environment_name=~\"$env\"} / 1000"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "none",
        "colorMode": "value"
      },
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Load avg 1m",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "system_load_average_1m{service_namespace=\"peep-bot\", service_name=~\"$service\", deployment_environment_name=~\"$env\"}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 2 } }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Container CPU",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "container_cpu_utilization{container_name=~\".*peepbot-backend.*\"}",
          "legendFormat": "{{container_name}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "description": "No container_* metrics are currently scraped — the otel-agent docker_stats receiver is not yet wired (or uses a different metric name). Targets the most plausible name; update once the receiver lands."
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Container memory",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "container_memory_usage{container_name=~\".*peepbot-backend.*\"}",
          "legendFormat": "{{container_name}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "description": "No container_* metrics are currently scraped — the otel-agent docker_stats receiver is not yet wired (or uses a different metric name). Targets the most plausible name; update once the receiver lands."
    }
  ]
}
