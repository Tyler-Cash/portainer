      "options": {
        "mode": "markdown",
        "content": "Continuous profiling for **peepbot-backend** via the Pyroscope async-profiler agent. CPU + allocation flame graphs below; jump here from any trace span via the Tempo **Profiles for this span** link (Tempo datasource `tracesToProfiles`)."
      }
    },
    {
      "id": 2,
      "type": "flamegraph",
      "title": "peepbot-backend — CPU flame graph",
      "gridPos": { "h": 18, "w": 12, "x": 0, "y": 3 },
      "datasource": { "type": "grafana-pyroscope-datasource", "uid": "pyroscope" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-pyroscope-datasource", "uid": "pyroscope" },
          "queryType": "profile",
          "profileTypeId": "process_cpu:cpu:nanoseconds:cpu:nanoseconds",
          "labelSelector": "{service_name=\"peepbot-backend\"}",
          "groupBy": []
        }
      ]
    },
    {
      "id": 3,
