{
  "uid": "homelab-overview",
  "title": "Homelab — Host Overview",
  "tags": ["homelab", "host", "overview"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "editable": false,
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "time() - node_boot_time_seconds{job=\"node-exporter\"}" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 0 } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Load 1m",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "node_load1{job=\"node-exporter\"}" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "value" },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 4 },
              { "color": "red", "value": 8 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Memory used",
      "gridPos": { "h": 4, "w": 5, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "1 - (node_memory_MemAvailable_bytes{job=\"node-exporter\"} / node_memory_MemTotal_bytes{job=\"node-exporter\"})"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "value" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 0.95 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Disk used (max %)",
      "gridPos": { "h": 4, "w": 5, "x": 13, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(1 - (node_filesystem_avail_bytes{job=\"node-exporter\", fstype!~\"tmpfs|overlay|squashfs|fuse.*\"} / node_filesystem_size_bytes{job=\"node-exporter\", fstype!~\"tmpfs|overlay|squashfs|fuse.*\"}))"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "value" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Containers running",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(container_cpu_utilization_ratio)"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "OOM kills (24h)",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "increase(node_vmstat_oom_kill{job=\"node-exporter\"}[24h])" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU utilization by mode",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"node-exporter\", mode!=\"idle\"}[5m])) / on() group_left() count(count by (cpu) (node_cpu_seconds_total{job=\"node-exporter\"}))",
          "legendFormat": "{{mode}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "stacking": { "mode": "normal", "group": "A" }, "fillOpacity": 30 } } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Load average",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "node_load1{job=\"node-exporter\"}", "legendFormat": "1m" },
        { "refId": "B", "expr": "node_load5{job=\"node-exporter\"}", "legendFormat": "5m" },
        { "refId": "C", "expr": "node_load15{job=\"node-exporter\"}", "legendFormat": "15m" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Memory breakdown",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "node_memory_MemTotal_bytes{job=\"node-exporter\"} - node_memory_MemAvailable_bytes{job=\"node-exporter\"}", "legendFormat": "Used" },
        { "refId": "B", "expr": "node_memory_Buffers_bytes{job=\"node-exporter\"}", "legendFormat": "Buffers" },
        { "refId": "C", "expr": "node_memory_Cached_bytes{job=\"node-exporter\"}", "legendFormat": "Cached" },
        { "refId": "D", "expr": "node_memory_MemFree_bytes{job=\"node-exporter\"}", "legendFormat": "Free" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "stacking": { "mode": "normal", "group": "A" }, "fillOpacity": 30 } } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Swap usage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "node_memory_SwapTotal_bytes{job=\"node-exporter\"} - node_memory_SwapFree_bytes{job=\"node-exporter\"}",
          "legendFormat": "Swap used"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "Disk usage by mount",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "1 - (node_filesystem_avail_bytes{job=\"node-exporter\", fstype!~\"tmpfs|overlay|squashfs|fuse.*\"} / node_filesystem_size_bytes{job=\"node-exporter\", fstype!~\"tmpfs|overlay|squashfs|fuse.*\"})",
          "legendFormat": "{{mountpoint}}",
          "instant": true
        }
      ],
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Disk I/O",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum by (device) (rate(node_disk_read_bytes_total{job=\"node-exporter\", device!~\"loop.*|dm-.*\"}[5m]))", "legendFormat": "{{device}} read" },
        { "refId": "B", "expr": "-sum by (device) (rate(node_disk_written_bytes_total{job=\"node-exporter\", device!~\"loop.*|dm-.*\"}[5m]))", "legendFormat": "{{device}} write" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Network throughput",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum by (device) (rate(node_network_receive_bytes_total{job=\"node-exporter\", device!~\"veth.*|docker.*|br-.*|lo\"}[5m]))", "legendFormat": "{{device}} rx" },
        { "refId": "B", "expr": "-sum by (device) (rate(node_network_transmit_bytes_total{job=\"node-exporter\", device!~\"veth.*|docker.*|br-.*|lo\"}[5m]))", "legendFormat": "{{device}} tx" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Network errors + drops",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum by (device) (rate(node_network_receive_errs_total{job=\"node-exporter\", device!~\"veth.*|docker.*|br-.*|lo\"}[5m]))", "legendFormat": "{{device}} rx errs" },
        { "refId": "B", "expr": "sum by (device) (rate(node_network_receive_drop_total{job=\"node-exporter\", device!~\"veth.*|docker.*|br-.*|lo\"}[5m]))", "legendFormat": "{{device}} rx drops" }
      ]
    },
    {
      "id": 15,
      "type": "table",
      "title": "SMART health",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "smartctl_device_smart_status", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true } } }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "FAIL", "color": "red" }, "1": { "text": "PASS", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Disk temperature",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "smartctl_device_temperature{temperature_type=\"current\"}", "legendFormat": "{{device}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "celsius", "max": 70, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 60 }] } } }
    }
  ]
}
